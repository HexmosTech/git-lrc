{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/blocking-review-git-commit.sh",
            "args": [],
            "timeout": 1260,
            "statusMessage": "Running blocking LiveReview gate before git commit"
          }
        ]
      }
    ]
  }
}